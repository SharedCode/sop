# Slim runtime image for the SOP quickstart demo.
# Built and published by .github/workflows/deliver.yml (GHCR).
FROM golang:1.26.4-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
COPY . .
RUN go mod download
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/quickstart ./examples/quickstart

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/quickstart /quickstart
ENTRYPOINT ["/quickstart"]
